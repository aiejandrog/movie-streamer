DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/moviestreamer
TMDB_API_KEY=your_tmdb_api_key_here
VIDEOS_DIR=./videos
SECRET_KEY=changeme

# CORS: comma-separated list of allowed frontend origins
# In production set this to your Railway app URL, e.g.:
# ALLOWED_ORIGINS=https://movie-streamer-production.up.railway.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Optional API key — leave empty for local dev (no auth enforced)
# Set in Railway dashboard to instantly lock down the API:
# API_KEY=some-random-secret-you-generate
API_KEY=
